        {
          "@type": "MenuSection",
          "name": "Bariatric or Low Carb Portions",
          "hasMenuItem": [
            {
              "@type": "MenuItem",
              "@id": "https://www.smashmeals.com/menu/103753",
              "name": "Bariatric friendly Cinnamon Protein Egg Soufflé Cup",
              "description": "Cinnamon Protein Egg Soufflé Cup\nA warm, fluffy, lightly sweet soufflé-style cup made from egg whites, vanilla protein, and a touch of cinnamon. Soft, airy, and extremely easy to tolerate — perfect for early bariatric stages or anyone wanting a gentle, high-protein morning meal.\nPortion (Single Serving)\n4 oz egg whites\n½ scoop vanilla whey isolate\n1 oz unsweetened almond milk\nCinnamon: ¼ teaspoon\nPinch of salt\n⭐ Macros (Single Serving)\n~170 calories\n26g protein\n3g carbs\n2g fat",
              "image": [
                "https://res.cloudinary.com/hpwejnwbc/image/upload/c_limit,f_auto,h_552,w_552/attachment_1768501609.3173716_m__t_image.jpg"
              ],
              "offers": [
                {
                  "@type": "Offer",
                  "price": "6.00",
                  "priceCurrency": "USD",
                  "availability": "https://schema.org/InStock"
                }
              ]
            },
            {
              "@type": "MenuItem",
              "@id": "https://www.smashmeals.com/menu/107369",
              "name": "Smoked Brisket & Egg Scramble (low carb)",
              "description": "Slow-smoked brisket folded into buttery scrambled eggs for a rich, protein-packed carnivore breakfast. Smoky, savory, and incredibly satisfying.\nCalories: 340\nProtein: 31 g\nFat: 22 g\nCarbs: 1 g",
              "image": [
                "https://res.cloudinary.com/hpwejnwbc/image/upload/c_limit,f_auto,h_552,w_552/attachment_1774033574.5983038_m__t_image.jpg"
              ],
