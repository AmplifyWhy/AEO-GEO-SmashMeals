    {
      "@type": "FAQPage",
      "@id": "https://www.smashmeals.com/#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How does SmashMeals meal prep delivery work in Tri-Cities TN?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Order by Thursday at 11:59 PM online. We prepare your meals fresh over the weekend in our 100% gluten-free kitchen. Meals are delivered fresh Monday morning with free local delivery on orders $50+."
          }
        },
        {
          "@type": "Question",
          "name": "Do you ship gluten-free meals nationwide?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes! We ship to 240+ cities nationwide using FedEx 2-day delivery."
          }
        },
        {
          "@type": "Question",
          "name": "Are your meals safe for celiac disease?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Absolutely. Every meal is prepared in our dedicated 100% gluten-free kitchen with zero cross-contamination risk."
          }
        },
        {
          "@type": "Question",
          "name": "What makes SmashMeals different from other meal prep services?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "SmashMeals is the Tri-Cities' FIRST and ONLY 100% gluten-free meal prep company."
          }
        }
      ]
    }
  ]
