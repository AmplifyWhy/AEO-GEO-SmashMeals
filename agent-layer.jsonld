                  "priceCurrency": "USD",
                  "availability": "https://schema.org/InStock"
                }
              ]
            },
            {
              "@type": "MenuItem",
              "@id": "https://www.smashmeals.com/menu/103754",
              "name": "Bariatric friendly Strawberry Protein Cheesecake Bite",
              "description": "Bariatric Snack: Strawberry Protein Cheesecake Bite\nA smooth, lightly sweet cheesecake-style bite made with Greek yogurt, protein powder, and real strawberries. Soft, creamy, and portion-controlled so bariatric patients can enjoy a snack without blowing their numbers.\nPortion (Single Bite)\n1.5 oz plain nonfat Greek yogurt\n¼ scoop vanilla whey isolate\n½ oz reduced-fat cream cheese\n1 tbsp finely diced strawberries\nA few drops sugar-free vanilla\nin a 3 oz cup.\n⭐ Macros (Single Bite)\n~90 calories\n12g protein\n4g carbs\n2g fat",
              "image": [
                "https://res.cloudinary.com/hpwejnwbc/image/upload/c_limit,f_auto,h_552,w_552/attachment_1768501537.6351628_m__t_image.jpg"
              ],
